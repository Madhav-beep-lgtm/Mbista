# Copy this file to .env and replace the values with your local or cPanel hosting details.
# On cPanel, DB_NAME and DB_USER usually include the cPanel account prefix, for example cpaneluser_dbname.

APP_ENV=production
APP_NAME="M.B Group"
APP_URL="https://www.mbca.com.np"

DB_HOST=localhost
DB_NAME=cpaneluser_dbname
DB_USER=cpaneluser_dbuser
DB_PASS=your_db_password
DB_CHARSET=utf8mb4

# Outgoing email (used by scheduled reports and future notifications).
# Leave MAIL_HOST empty to keep the safe default: emails are written to
# storage/mail/ instead of being sent. On cPanel, create an email account
# (cPanel -> Email Accounts) and use its SMTP settings here.
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=
MAIL_FROM_NAME="M.B Group"
# Or, to use the host's built-in PHP mail() instead of SMTP:
# MAIL_TRANSPORT=mail
