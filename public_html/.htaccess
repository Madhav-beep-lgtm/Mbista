Options -Indexes
DirectoryIndex index.php

<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set X-XSS-Protection "1; mode=block"
</IfModule>

<FilesMatch "^(\.env|composer\.(json|lock)|package\.(json|lock)|yarn\.lock)$">
    Require all denied
</FilesMatch>

<IfModule mod_rewrite.c>
    RewriteEngine On

    # Optional production canonical redirect.
    # Enable only after DNS and SSL are ready for the final cPanel domain.
    # RewriteCond %{HTTPS} !=on [OR]
    # RewriteCond %{HTTP_HOST} !^www\.mbca\.com\.np$ [NC]
    # RewriteRule ^ https://www.mbca.com.np%{REQUEST_URI} [R=301,L]

    # /login.php is the single sign-in page. The old admin entry points are kept
    # as external 301s so bookmarks land on it visibly instead of dead-ending.
    RewriteRule ^adminlogin/?$ /login.php [R=301,QSA,L]

    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^ index.php [QSA,L]
</IfModule>
